{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    // Cambia "node" por "bundler" (recomendado para Next.js)
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    // Elimina "baseUrl" (obsoleto) y usa solo "paths"
    "paths": {
      "@/*": ["./*"]
    }
    // Si quieres silenciar las advertencias de obsolescencia (no recomendado a largo plazo):
    // "ignoreDeprecations": "6.0"
  },
  // ⬇️ include y exclude fuera de compilerOptions (en la raíz)
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "app/api/admin/productos/route.js"
  ],
  "exclude": ["node_modules"]
}